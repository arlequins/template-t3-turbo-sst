{
  "extends": "@acme/tsconfig/compiled-package.json",
  "compilerOptions": {
    /** Emit `.js` so Node/Vite can resolve `@acme/env` without a TS loader (see `package.json` `exports`). */
    "emitDeclarationOnly": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
