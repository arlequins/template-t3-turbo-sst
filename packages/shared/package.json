{
  "name": "@acme/shared",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./seed": {
      "types": "./dist/seed.d.ts",
      "default": "./src/seed.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@acme/env": "workspace:*",
    "@acme/types": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
