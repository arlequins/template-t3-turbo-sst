{
  "name": "template-t3-turbo-sst",
  "version": "1.1.1",
  "private": true,
  "engines": {
    "node": "^24.14.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "architecture:check": "node scripts/check-architecture.mjs",
    "preinstall": "node scripts/check-runtime.mjs",
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:pull": "turbo -F @acme/db-backbone pull",
    "db:push": "turbo -F @acme/db-backbone push",
    "db:create-migration": "pnpm -C packages/db-backbone create-migration",
    "db:check": "turbo -F @acme/db-backbone check-migrations",
    "db:backup": "pnpm exec dotenv -e .env -- node scripts/database-backup.mjs",
    "db:migrate": "turbo -F @acme/db-backbone migrate",
    "db:restore:verify": "pnpm exec dotenv -e .env -- node scripts/database-restore-verify.mjs",
    "db:seed": "turbo -F @acme/db-backbone seed",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:start": "pnpm exec dotenv -e .env.localhost -- docker compose up -d --wait postgres",
    "db:stop": "docker compose down",
    "db:studio": "turbo -F @acme/db-backbone studio",
    "dev": "turbo watch dev --continue",
    "dev:local": "pnpm db:start && pnpm exec dotenv -e .env.localhost -- pnpm db:setup && pnpm exec dotenv -e .env.localhost -- pnpm dev",
    "dev:next": "turbo watch dev -F @acme/web...",
    "dev:sst": "turbo run sst:dev --continue -F @acme/web -F @acme/api -F @acme/batch",
    "batch:run": "pnpm -C apps/batch with-env pnpm dlx tsx scripts/dev.ts",
    "check": "biome check .",
    "check:changed": "node scripts/check-changed.mjs",
    "check:fix": "biome check . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "lint:ws": "pnpm dlx sherif@latest",
    "lint:dead-code": "dotenv -e .env.example -- knip",
    "postinstall": "pnpm lint:ws",
    "prepare": "husky",
    "security:licenses": "node scripts/check-licenses.mjs",
    "storybook": "pnpm --filter @acme/ui storybook",
    "storybook:build": "pnpm --filter @acme/ui build-storybook",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "sst:ws": "node ./scripts/sst-workspace.mjs",
    "test": "pnpm test:runtime && pnpm test:automation && pnpm test:template-init && pnpm architecture:check && turbo run test",
    "test:automation": "node --test scripts/validate-deployment-input.test.mjs",
    "test:sst": "node scripts/test-sst.mjs",
    "test:runtime": "node --test scripts/check-runtime.test.mjs",
    "test:template-init": "node --test scripts/template-init.test.mjs scripts/template-doctor.test.mjs",
    "test:template-matrix": "node --test scripts/template-matrix.test.mjs && node scripts/template-matrix.mjs",
    "test:template-output": "node scripts/test-template-output.mjs",
    "template:init": "node scripts/template-init.mjs",
    "template:doctor": "node scripts/template-doctor.mjs",
    "test:e2e": "node scripts/test-e2e.mjs",
    "test:e2e:headed": "node scripts/test-e2e.mjs --headed",
    "test:migration-upgrade": "node scripts/test-migration-upgrade.mjs",
    "test:integration": "node scripts/test-integration.mjs",
    "test:generators": "node scripts/test-generators.mjs",
    "env:pull": "pnpm -F @acme/sst-bootstrap run env:pull --",
    "env:push": "pnpm -F @acme/sst-bootstrap run env:push --",
    "env:check": "node scripts/check-env-sync.mjs",
    "example:remove": "node scripts/example-crud.mjs remove",
    "example:regenerate": "node scripts/example-crud.mjs regenerate",
    "gen:feature": "turbo gen feature"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "catalog:",
    "@turbo/gen": "^2.10.5",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "knip": "catalog:",
    "turbo": "^2.10.5",
    "typescript": "catalog:"
  }
}
