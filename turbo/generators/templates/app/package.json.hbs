{
  "name": "{{ scope }}/{{ name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "dev": "tsx watch src/index.ts",
    "format": "biome format .",
    "lint": "biome lint .",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "{{ scope }}/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
