SST_STAGE=offline
SEED_SAMPLE_DATA=false
SST_AWS_REGION=us-east-1

DATABASE_HOST=localhost
DATABASE_PORT=55433
POSTGRES_HOST_PORT=55433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=app
DATABASE_SSL_MODE=disable
POSTGRES_POOL_MAX=10

OIDC_MOCK_PORT=5556
OIDC_MOCK_ISSUER=http://localhost:5556
OIDC_ISSUER_URL=http://localhost:5556
OIDC_AUDIENCE=http://localhost:5000
OIDC_ALLOWED_ALGORITHMS=RS256
AUTH_BOOTSTRAP_ADMIN_IDENTITIES=http://localhost:5556|local-user
# OIDC_PROVIDERS_JSON=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:5556
NEXT_PUBLIC_OIDC_CLIENT_ID=local-web
NEXT_PUBLIC_OIDC_RESOURCE=http://localhost:5000
NEXT_PUBLIC_OIDC_SCOPE=openid profile email

API_PORT=5000
API_CORS_ORIGINS=http://localhost:3000
API_BODY_LIMIT_BYTES=1048576
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60

# Optional local OTLP/HTTP collector. Export is disabled when omitted.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=api

# Optional S3-compatible local cache. Omit the bucket to disable cache use.
# S3_CACHE_BUCKET=local-cache
# S3_CACHE_PREFIX=offline
# S3_CACHE_TTL_SECONDS=300
# S3_CACHE_ENDPOINT=http://localhost:9000
# S3_CACHE_FORCE_PATH_STYLE=true
# S3_UPLOAD_BUCKET=local-uploads
# S3_UPLOAD_PREFIX=uploads
