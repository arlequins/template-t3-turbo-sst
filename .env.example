# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# Optional: AWS Secrets Manager ↔ `.env` via `pnpm env:pull` / `pnpm env:push`.
# `ENV_TARGET` or `--env-target`: `root` / `.` / omit → repo root `.env`; `web` / `api` → `apps/<name>/.env` (that app folder must exist).
# Pull overwrites the target file only (no merge). `--out` / `--file` override the default path.
# SM secret name: prefix `{SM_PREFIX or SST_STAGE or STAGE}/{SECRET_NAME}/{ENV_TARGET}` (omit prefix segment if unused).
#   SECRET_NAME=core/environments, ENV_TARGET=root → core/environments/root
#   + SM_PREFIX=offline (or --stage offline) → offline/core/environments/root
# Full ARN as SECRET_NAME skips composition.
# Plain-text secret in SM → one env key (`SECRETS_MANAGER_PLAIN_KEY`, default SECRET_VALUE); JSON → one key per top-level field.
# Push: default input path follows `ENV_TARGET` the same way as pull’s default output.
# SECRET_NAME=core/environments
# ENV_TARGET=root
# SM_PREFIX=offline
# AWS_REGION=ap-northeast-1
# (legacy alias for SECRET_NAME) SSM_ENV_PATH=

# Amazon RDS PostgreSQL (add sslmode=require unless using a tunnel).
# Optional: POSTGRES_POOL_MAX=10 (see packages/db/src/client.ts)
GLOBAL_DATABASE_HOST=your-db.region.rds.amazonaws.com
GLOBAL_DATABASE_PORT=5432
GLOBAL_DATABASE_USER=your-db-user
GLOBAL_DATABASE_PASSWORD=your-db-password
GLOBAL_DATABASE_NAME=your-db-name
GLOBAL_DATABASE_SSL=true
