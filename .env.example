# =============================================================================
# Root `.env` template
# =============================================================================
# Copy to `.env` and fill in values. Do not commit real secrets.
# Keep this file updated when you add new variables (see also `turbo.json` Ôćĺ `globalEnv`).

# =============================================================================
# AWS Secrets Manager Ôćö local `.env` (`pnpm env:pull` / `pnpm env:push`)
# =============================================================================
# Scripts: `tooling/sst-bootstrap/scripts/`. Set these when using pull/push (optional).
#
# ENV_TARGET / --env-target: `root` | `.` | omit Ôćĺ repo root `.env`; `web` | `api` Ôćĺ `apps/<name>/.env`
# Pull overwrites the target file only (no merge). Use --out / --file to override path.
#
# Secret name = `{SM_PREFIX or SST_STAGE or STAGE}/{SECRET_NAME}/{ENV_TARGET}` (omit unused segments).
#   Example: SECRET_NAME=environments, ENV_TARGET=root Ôćĺ secret id `environments/root`
#   With SM_PREFIX=offline Ôćĺ `offline/environments/root`
# Full secret ARN as SECRET_NAME skips prefix composition.
# Plain-text secret Ôćĺ one key (SECRETS_MANAGER_PLAIN_KEY, default SECRET_VALUE); JSON Ôćĺ one key per field.
#
# SECRET_NAME=environments
# ENV_TARGET=root
# SM_PREFIX=offline
# AWS_REGION=ap-northeast-1
# SSM_ENV_PATH=   # legacy alias for SECRET_NAME

# =============================================================================
# SST & AWS (all `apps/*/sst.config.ts` providers)
# =============================================================================
# Logical deploy stage: also drives `resolveDeployStage()` (batch schedules, optional branching in
# `pnpm db:seed` ÔÇö see `packages/db-backbone/README.md` and `packages/shared/README.md`).
SST_STAGE=offline
# Required only to load example data outside `offline` and `test`.
SEED_SAMPLE_DATA=false

# Local dev only: named AWS profile for `sst dev` / `sst deploy` (omit in CI).
SST_AWS_PROFILE=my-dev-profile

# Region for SST AWS provider (S3, CloudFront, Lambda, etc.). Default in each `sst.config.ts` if unset.
SST_AWS_REGION=us-east-1

# =============================================================================
# Lambda VPC ÔÇö `@acme/env` `vpcFromEnv()` Ôćĺ `apps/api` and `apps/batch` functions
# =============================================================================
# Comma-separated IDs. If SUBNET_IDS or SECURITY_GROUP_IDS is empty, Lambdas are not in a VPC.
# VPC_ID is optional (documentation / future use); attachment uses subnet + security group IDs only.
#
# VPC_ID=vpc-0123456789abcdef0
# SUBNET_IDS=subnet-0aaa...,subnet-0bbb...
# SECURITY_GROUP_IDS=sg-0ccc...

# =============================================================================
# PostgreSQL ÔÇö `@acme/env` `loadDatabaseEnv()` Ôćĺ `@acme/db-backbone` (Drizzle, postgres.js)
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=app
DATABASE_SSL_MODE=disable

# Pool size for postgres.js (default 10). See `packages/env/src/database.ts`.
# POSTGRES_POOL_MAX=10

# =============================================================================
# OpenID Connect ÔÇö SPA Authorization Code + PKCE and API JWT validation
# =============================================================================
# Register these browser redirect URIs with the provider:
#   http://localhost:3000/auth/callback/
#   http://localhost:3000/auth/logout-callback/
OIDC_MOCK_PORT=5556
OIDC_MOCK_ISSUER=http://localhost:5556
OIDC_ISSUER_URL=http://localhost:5556
OIDC_AUDIENCE=http://localhost:5000
# OIDC_JWKS_URI=https://idp.example.com/.well-known/jwks.json
OIDC_ALLOWED_ALGORITHMS=RS256

NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:5556
NEXT_PUBLIC_OIDC_CLIENT_ID=local-web
NEXT_PUBLIC_OIDC_RESOURCE=http://localhost:5000
NEXT_PUBLIC_OIDC_SCOPE=openid profile email

# =============================================================================
# Next.js (`apps/web`) ÔÇö baked into StaticSite at deploy; dev uses localhost defaults below
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# Hono API. CORS defaults to NEXT_PUBLIC_SITE_URL when omitted.
API_PORT=5000
API_CORS_ORIGINS=http://localhost:3000

# AWS API endpoint. `function-url` is the lowest-cost default; `api-gateway` adds
# managed access logs, custom domains, and per-stage throttling.
API_DEPLOYMENT_PRESET=function-url
# API_CUSTOM_DOMAIN=api.example.com

# Function URL preset only. Enabling WAF or a custom domain adds an SST Router
# (CloudFront) in front of the Function URL.
API_WAF_ENABLED=false

# API Gateway preset only. Defaults: 100 requests/second, burst 200.
# API_THROTTLE_RATE_LIMIT=100
# API_THROTTLE_BURST_LIMIT=200
