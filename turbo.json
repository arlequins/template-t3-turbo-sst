{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo", "^build"]
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "pull": {
      "cache": false,
      "interactive": true
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "check-migrations": {
      "cache": false
    },
    "migrate": {
      "cache": false
    },
    "seed": {
      "cache": false
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "sst:dev": {
      "cache": false,
      "persistent": true
    },
    "env:pull": {
      "cache": false
    },
    "env:push": {
      "cache": false
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    }
  },
  "globalEnv": [
    "SST_STAGE",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_API_URL",
    "VPC_ID",
    "SUBNET_IDS",
    "SECURITY_GROUP_IDS",
    "DATABASE_HOST",
    "DATABASE_PORT",
    "DATABASE_USER",
    "DATABASE_PASSWORD",
    "DATABASE_NAME",
    "POSTGRES_POOL_MAX",
    "API_CORS_ORIGINS",
    "API_PORT"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "NO_COLOR",
    "TERM",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event",
    "SECRET_NAME",
    "SECRETS_MANAGER_PLAIN_KEY",
    "SSM_ENV_PATH",
    "SST_STAGE",
    "STAGE",
    "SST_AWS_PROFILE",
    "SST_AWS_REGION",
    "AWS_PROFILE",
    "AWS_REGION",
    "ENV_TARGET",
    "SM_PREFIX",
    "STATE_MACHINE_ARN"
  ]
}
