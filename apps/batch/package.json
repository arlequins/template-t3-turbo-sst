{
  "name": "@acme/batch",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "run": "pnpm with-env pnpm dlx tsx scripts/dev.ts",
    "run:pipeline": "pnpm with-env pnpm dlx tsx scripts/run-pipeline.ts",
    "sst:dev": "pnpm with-env sst dev",
    "sst:deploy": "pnpm with-env sst deploy",
    "sst:install": "sst install",
    "sst:remove": "pnpm with-env sst remove",
    "format": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/db-backbone": "workspace:^",
    "@acme/env": "workspace:*",
    "@acme/service": "workspace:^",
    "@aws-sdk/client-sfn": "^3.1089.0"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "catalog:",
    "sst": "4.17.1",
    "typescript": "catalog:"
  }
}
