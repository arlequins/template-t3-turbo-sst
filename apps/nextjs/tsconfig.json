{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "paths": {
      "~/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "src",
    "next.config.js",
    "eslint.config.ts",
    ".next/types/**/*.ts",
    "sst.config.ts",
    "sst-globals.d.ts"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
