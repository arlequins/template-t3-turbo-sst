# SST stage
SST_STAGE=localhost

# SST (S3 + CloudFront): from repo root, `pnpm sst:dev` or deploy with:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API server base URL (no trailing `/api/trpc`). The Next.js tRPC client resolves the batch URL as `{NEXT_PUBLIC_API_URL}/api/trpc`.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional, local only: AWS named profile for `sst dev` / `sst deploy` (omit in CI and production env).
# SST_AWS_PROFILE=my-dev-profile
