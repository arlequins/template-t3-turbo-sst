{
  "name": "@acme/api",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env tsx watch src/dev.ts",
    "build": "tsc --noEmit",
    "start": "pnpm with-env tsx src/dev.ts",
    "sst:dev": "pnpm with-env sst dev",
    "sst:deploy": "pnpm with-env sst deploy",
    "sst:install": "pnpm with-env sst install",
    "sst:remove": "pnpm with-env sst remove",
    "format": "biome format .",
    "lint": "biome lint .",
    "test": "pnpm with-env vitest run",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/db-backbone": "workspace:*",
    "@acme/env": "workspace:*",
    "@acme/logger": "workspace:*",
    "@acme/service": "workspace:*",
    "@acme/trpc": "workspace:*",
    "@aws-sdk/client-eventbridge": "catalog:",
    "@aws-sdk/client-scheduler": "catalog:",
    "@aws-sdk/client-sqs": "catalog:",
    "@trpc/server": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@hono/node-server": "catalog:",
    "@types/node": "catalog:",
    "sst": "4.17.1",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
