# SST stage
SST_STAGE=localhost

# Optional, local only: AWS named profile for `sst dev` / `sst deploy` (omit in CI and production env).
# SST_AWS_PROFILE=my-dev-profile

# Optional: override default region for SST AWS provider (StaticSite S3, etc.). Default in sst.config.ts is us-east-1.
# SST_AWS_REGION=us-east-1
